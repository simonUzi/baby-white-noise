/* 哄睡统计页 - 暗黑主题 */
.container {
  padding: 20rpx;
  padding-bottom: 100rpx;
  min-height: 100vh;
}

.page-title {
  font-size: 36rpx;
  font-weight: 600;
  color: rgba(255, 255, 255, 0.9);
  text-align: center;
  padding: 30rpx 0;
}

.stats-section {
  background: rgba(255, 255, 255, 0.06);
  border: 1rpx solid rgba(255, 255, 255, 0.08);
  margin: 0 30rpx 20rpx;
  padding: 30rpx;
  border-radius: 16rpx;
}

.stats-title {
  font-size: 28rpx;
  font-weight: 600;
  color: rgba(255, 255, 255, 0.9);
  margin-bottom: 24rpx;
  padding-bottom: 16rpx;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.1);
}

.stat-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 0;
  font-size: 28rpx;
}

.stat-item.highlight {
  background: rgba(82, 196, 26, 0.1);
  margin: 8rpx -20rpx;
  padding: 16rpx 20rpx;
  border-radius: 8rpx;
}

.stat-label {
  color: rgba(255, 255, 255, 0.5);
}

.stat-value {
  font-weight: 600;
  color: rgba(255, 255, 255, 0.9);
}

.stat-value.trend {
  color: #52c41a;
}

.rank-item {
  display: flex;
  align-items: center;
  padding: 12rpx 0;
  font-size: 26rpx;
}

.rank-num {
  width: 40rpx;
  font-weight: 600;
  color: #a855f7;
}

.rank-name {
  flex: 1;
  color: rgba(255, 255, 255, 0.9);
}

.rank-duration {
  color: rgba(255, 255, 255, 0.5);
  font-weight: 500;
}

.empty-ranking {
  text-align: center;
  padding: 30rpx 0;
  color: rgba(255, 255, 255, 0.4);
  font-size: 26rpx;
}

.tip-box {
  background: rgba(250, 140, 22, 0.1);
  margin: 30rpx;
  padding: 30rpx;
  border-radius: 16rpx;
  border-left: 8rpx solid #fa8c16;
}

.tip-title {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: #fa8c16;
  margin-bottom: 12rpx;
}

.tip-content {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.7);
  line-height: 1.6;
}
