/* 哄睡记录页 - 暗黑主题 */
.container {
  padding: 20rpx;
  padding-bottom: 100rpx;
  min-height: 100vh;
}

.page-title {
  font-size: 36rpx;
  font-weight: 600;
  color: rgba(255, 255, 255, 0.9);
  text-align: center;
  padding: 30rpx 0;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding-top: 200rpx;
  color: rgba(255, 255, 255, 0.5);
}

.empty-icon {
  font-size: 120rpx;
  margin-bottom: 32rpx;
  opacity: 0.5;
}

.empty-text {
  font-size: 32rpx;
  margin-bottom: 16rpx;
  color: rgba(255, 255, 255, 0.7);
}

.empty-hint {
  font-size: 26rpx;
  text-align: center;
  max-width: 400rpx;
}

.date-header {
  font-size: 28rpx;
  font-weight: 600;
  color: rgba(255, 255, 255, 0.5);
  margin: 30rpx 30rpx 16rpx;
}

.record-card {
  background: rgba(255, 255, 255, 0.06);
  border: 1rpx solid rgba(255, 255, 255, 0.08);
  margin: 0 30rpx 16rpx;
  padding: 30rpx;
  border-radius: 16rpx;
}

.record-time {
  display: flex;
  align-items: center;
  justify-content: space-between;
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.9);
  margin-bottom: 12rpx;
}

.record-time .arrow {
  color: #a855f7;
  font-weight: 600;
}

.record-detail {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.5);
}

.day-summary {
  background: rgba(168, 85, 247, 0.15);
  margin: 0 30rpx 20rpx;
  padding: 20rpx 30rpx;
  border-radius: 12rpx;
  font-size: 26rpx;
  color: #a855f7;
  text-align: center;
}

.stats-entry {
  background: rgba(255, 255, 255, 0.06);
  border: 1rpx solid rgba(255, 255, 255, 0.08);
  margin: 40rpx 30rpx 20rpx;
  padding: 30rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  font-size: 28rpx;
  color: #a855f7;
  font-weight: 500;
}

.stats-entry .arrow {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.5);
}
