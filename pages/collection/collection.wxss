/* 收藏页 - 暗黑主题 */
.container {
  padding: 20rpx;
  padding-bottom: 200rpx;
  min-height: 100vh;
}

/* 页面标题 */
.page-title {
  font-size: 36rpx;
  font-weight: 600;
  color: rgba(255, 255, 255, 0.9);
  margin: 20rpx 10rpx 32rpx;
  display: flex;
  align-items: center;
  gap: 12rpx;
}

/* 哄睡记录入口 */
.sleep-record-entry {
  background: rgba(255, 255, 255, 0.06);
  border: 1rpx solid rgba(255, 255, 255, 0.08);
  margin: 0 10rpx 20rpx;
  padding: 30rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
}

.entry-icon {
  font-size: 40rpx;
  margin-right: 16rpx;
}

.entry-text {
  flex: 1;
  font-size: 30rpx;
  font-weight: 500;
  color: rgba(255, 255, 255, 0.9);
}

.entry-arrow {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.5);
}

.sound-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20rpx;
  padding: 10rpx;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding-top: 200rpx;
  color: rgba(255, 255, 255, 0.5);
  text-align: center;
  padding-left: 60rpx;
  padding-right: 60rpx;
}

.empty-icon {
  font-size: 120rpx;
  margin-bottom: 32rpx;
  opacity: 0.5;
}

.empty-text {
  font-size: 32rpx;
  color: rgba(255, 255, 255, 0.9);
  margin-bottom: 16rpx;
  font-weight: 500;
}

.empty-hint {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.5);
  line-height: 1.5;
}

/* 哄睡记录横幅 */
.recording-banner {
  background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);
  color: white;
  padding: 24rpx 30rpx;
  margin: 0 10rpx 20rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  gap: 16rpx;
  box-shadow: 0 4rpx 12rpx rgba(240, 147, 251, 0.3);
}

.recording-icon {
  font-size: 36rpx;
}

.recording-text {
  font-size: 28rpx;
  font-weight: 500;
}

/* 弹窗样式 */
.modal-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.7);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 200;
}

.modal-content {
  background: #1a1a2e;
  border: 1rpx solid rgba(255, 255, 255, 0.1);
  border-radius: 20rpx;
  padding: 40rpx 30rpx;
  width: 80%;
  max-width: 500rpx;
}

.modal-title {
  font-size: 32rpx;
  font-weight: 600;
  text-align: center;
  margin-bottom: 40rpx;
  color: rgba(255, 255, 255, 0.9);
}

.timer-picker {
  margin-bottom: 40rpx;
}

.picker-display {
  padding: 24rpx;
  background: rgba(255, 255, 255, 0.06);
  border-radius: 12rpx;
  font-size: 28rpx;
  text-align: center;
  color: rgba(255, 255, 255, 0.9);
}

.modal-buttons {
  display: flex;
  gap: 20rpx;
}

.modal-buttons .btn {
  flex: 1;
  height: 80rpx;
  line-height: 80rpx;
  border-radius: 40rpx;
  font-size: 28rpx;
  border: none;
  padding: 0;
}

.modal-buttons .cancel {
  background: rgba(255, 255, 255, 0.06);
  color: rgba(255, 255, 255, 0.5);
}

.modal-buttons .confirm {
  background: linear-gradient(135deg, #7c3aed 0%, #a855f7 100%);
  color: #ffffff;
}
