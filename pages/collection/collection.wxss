.container {
  padding: 20rpx;
  padding-bottom: 200rpx;
  min-height: 100vh;
}

/* 哄睡记录入口 */
.sleep-record-entry {
  background: white;
  margin: 0 10rpx 20rpx;
  padding: 30rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.08);
}

.entry-icon {
  font-size: 40rpx;
  margin-right: 16rpx;
}

.entry-text {
  flex: 1;
  font-size: 30rpx;
  font-weight: 500;
  color: #333;
}

.entry-arrow {
  font-size: 28rpx;
  color: #999;
}

.sound-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20rpx;
  padding: 10rpx;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding-top: 200rpx;
  color: #999;
}

.empty-icon {
  font-size: 120rpx;
  margin-bottom: 32rpx;
  opacity: 0.5;
}

.empty-text {
  font-size: 32rpx;
  margin-bottom: 16rpx;
}

.empty-hint {
  font-size: 26rpx;
}

/* 分享卡片样式 */
.share-card {
  background: #fff8e1;
  border-radius: 16rpx;
  padding: 30rpx;
  margin: 20rpx 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 20rpx;
  border: 1px solid #ffe082;
}

.share-title {
  font-size: 28rpx;
  color: #f57c00;
  text-align: center;
  font-weight: 500;
}

.share-btn {
  background: #4A6FA5;
  color: white;
  border-radius: 40rpx;
  padding: 16rpx 40rpx;
  font-size: 28rpx;
  border: none;
  box-shadow: 0 4rpx 12rpx rgba(74, 111, 165, 0.3);
}

.share-btn:active {
  background: #3a5a8a;
  transform: translateY(2rpx);
  box-shadow: 0 2rpx 8rpx rgba(74, 111, 165, 0.3);
}

/* 弹窗样式 */
.modal-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 200;
}

.modal-content {
  background: #ffffff;
  border-radius: 16rpx;
  padding: 40rpx 30rpx;
  width: 80%;
  max-width: 500rpx;
}

.modal-title {
  font-size: 32rpx;
  font-weight: 600;
  text-align: center;
  margin-bottom: 40rpx;
  color: #333;
}

.timer-picker {
  margin-bottom: 40rpx;
}

.picker-display {
  padding: 24rpx;
  background: #f5f5f5;
  border-radius: 8rpx;
  font-size: 28rpx;
  text-align: center;
  color: #333;
}

.modal-buttons {
  display: flex;
  gap: 20rpx;
}

.modal-buttons .btn {
  flex: 1;
  height: 80rpx;
  line-height: 80rpx;
  border-radius: 40rpx;
  font-size: 28rpx;
  border: none;
  padding: 0;
}

.modal-buttons .cancel {
  background: #f0f0f0;
  color: #666;
}

.modal-buttons .confirm {
  background: #4A6FA5;
  color: #ffffff;
}
