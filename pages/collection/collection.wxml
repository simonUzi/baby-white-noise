<view class="container">
  <view class="header">
    <text class="title">我的收藏</text>
    <text class="subtitle">您收藏的白噪音</text>
  </view>

  <view class="favorites-list">
    <block wx:if="{{favoriteSounds.length > 0}}">
      <view class="sounds-grid">
        <block wx:for="{{favoriteSounds}}" wx:key="id">
          <sound-card
            sound="{{item}}"
            isPlaying="{{currentSound && currentSound.id === item.id && isPlaying}}"
            bind:play="onPlaySound"
            bind:togglefavorite="onToggleFavorite"
          />
        </block>
      </view>
    </block>
    <view wx:else class="empty-state">
      <text class="empty-text">您还没有收藏任何声音</text>
      <text class="empty-hint">点击声音卡片上的星星即可收藏</text>
    </view>
  </view>
</view>
