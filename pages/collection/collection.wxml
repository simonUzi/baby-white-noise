<view class="container">
  <!-- 哄睡记录入口 -->
  <view class="sleep-record-entry" bindtap="goToSleepRecord">
    <text class="entry-icon">📋</text>
    <text class="entry-text">我的哄睡日记</text>
    <text class="entry-arrow">→</text>
  </view>

  <!-- 哄睡记录中横幅 -->
  <view wx:if="{{isRecording}}" class="recording-banner">
    <text class="recording-icon">🛌</text>
    <text class="recording-text">哄睡中... {{recordingTime}}</text>
  </view>

  <!-- 空状态 -->
  <view wx:if="{{collectedSounds.length === 0}}" class="empty-state">
    <view class="empty-icon">⭐</view>
    <view class="empty-text">还没有收藏的声音</view>
    <view class="empty-hint">去首页点击星星收藏喜欢的声音吧</view>
  </view>

  <!-- 收藏列表 -->
  <view wx:else class="sound-grid">
    <sound-card
      wx:for="{{collectedSounds}}" wx:for-item="sound" wx:key="id"
      sound="{{sound}}"
      isPlaying="{{isPlaying && currentSound && currentSound.id === sound.id}}"
      bindplay="onPlaySound"
      bindtogglefavorite="onToggleFavorite"
    />
  </view>

  <!-- 底部播放控制栏 -->
  <player-bar
    currentSound="{{currentSound}}"
    isPlaying="{{isPlaying}}"
    remainingSeconds="{{remainingSeconds}}"
    bindplaytoggle="onPlayToggle"
    bindsettimer="openTimerPicker"
    bindstop="onStop"
  />

  <!-- 推荐给好友卡片 (有收藏内容时显示) -->
  <view wx:if="{{collectedSounds.length > 0}}" class="share-card">
    <view class="share-title">🎉 觉得好用？推荐给宝妈好友</view>
    <button class="share-btn" open-type="share">
      分享给好友
    </button>
  </view>

  <!-- 定时选择弹窗 -->
  <view wx:if="{{showTimerPicker}}" class="modal-overlay" bindtap="closeTimerPicker">
    <view class="modal-content" catchtap>
      <view class="modal-title">选择播放时长</view>
      <view class="timer-picker">
        <picker mode="selector" range="{{[5,10,15,20,25,30,45,60,90,120]}}" value="{{timerPickerIndex}}" bindchange="onTimerChange">
          <view class="picker-display">
            当前选择: {{timerMinutes}} 分钟
          </view>
        </picker>
      </view>
      <view class="modal-buttons">
        <button class="btn cancel" bindtap="closeTimerPicker">取消</button>
        <button class="btn confirm" bindtap="startTimer">确定</button>
      </view>
    </view>
  </view>
</view>
