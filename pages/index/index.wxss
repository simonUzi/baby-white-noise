.container {
  padding: 20rpx;
  padding-bottom: 200rpx;
}

.category-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  margin: 32rpx 0 16rpx 10rpx;
}

.sound-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20rpx;
  padding: 0 10rpx;
}

/* 弹窗样式 */
.modal-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 200;
}

.modal-content {
  background: #ffffff;
  border-radius: 16rpx;
  padding: 40rpx 30rpx;
  width: 80%;
  max-width: 500rpx;
}

.modal-title {
  font-size: 32rpx;
  font-weight: 600;
  text-align: center;
  margin-bottom: 40rpx;
  color: #333;
}

.timer-picker {
  margin-bottom: 40rpx;
}

.picker-display {
  padding: 24rpx;
  background: #f5f5f5;
  border-radius: 8rpx;
  font-size: 28rpx;
  text-align: center;
  color: #333;
}

.modal-buttons {
  display: flex;
  gap: 20rpx;
}

.modal-buttons .btn {
  flex: 1;
  height: 80rpx;
  line-height: 80rpx;
  border-radius: 40rpx;
  font-size: 28rpx;
  border: none;
  padding: 0;
}

.modal-buttons .cancel {
  background: #f0f0f0;
  color: #666;
}

.modal-buttons .confirm {
  background: #4A6FA5;
  color: #ffffff;
}

/* 哄睡记录横幅 */
.recording-banner {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: white;
  padding: 24rpx 30rpx;
  margin: 20rpx;
  margin-top: 0;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  gap: 16rpx;
  box-shadow: 0 4rpx 12rpx rgba(102, 126, 234, 0.3);
}

.recording-icon {
  font-size: 36rpx;
}

.recording-text {
  font-size: 28rpx;
  font-weight: 500;
}