/* 录音页 - 情感化暗黑主题 */
.container {
  min-height: 100vh;
  padding: 20rpx;
  /* 留出底部按钮高度 + tabBar 空间 */
  padding-bottom: 240rpx;
}

.bottom-spacer {
  height: 140rpx;
}

/* 顶部情感化标题卡片 */
.header-card {
  background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);
  border-radius: 24rpx;
  padding: 32rpx;
  margin: 0 10rpx 32rpx;
  display: flex;
  align-items: center;
  gap: 20rpx;
  box-shadow: 0 8rpx 24rpx rgba(240, 147, 251, 0.3);
}

.header-icon {
  font-size: 56rpx;
}

.header-content {
  flex: 1;
}

.header-title {
  font-size: 32rpx;
  font-weight: 600;
  color: white;
  margin-bottom: 8rpx;
}

.header-desc {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.85);
  line-height: 1.5;
}

/* 录音列表区域 */
.recordings-section {
  margin-bottom: 32rpx;
}

.section-title {
  font-size: 28rpx;
  font-weight: 500;
  color: rgba(255, 255, 255, 0.5);
  margin: 0 10rpx 16rpx;
}

/* 悬浮录音按钮：紧贴 tabBar 上方 */
.float-record-button {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: rgba(10, 10, 26, 0.95);
  backdrop-filter: blur(20rpx);
  border-top: 1rpx solid rgba(255, 255, 255, 0.08);
  box-sizing: border-box;
  padding: 20rpx 30rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  z-index: 100;
}

/* 网格布局，和首页声音列表完全一致 */
.sound-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20rpx;
  padding: 0 10rpx;
}

/* 空状态 - 情感化 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  margin-top: 160rpx;
  padding: 0 60rpx;
  text-align: center;
}

.empty-icon {
  font-size: 120rpx;
  margin-bottom: 24rpx;
}

.empty-text {
  font-size: 32rpx;
  color: rgba(255, 255, 255, 0.9);
  margin-bottom: 12rpx;
  font-weight: 500;
}

.empty-hint {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.5);
  line-height: 1.5;
}

/* 哄睡记录横幅 */
.recording-banner {
  background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);
  color: white;
  padding: 24rpx 30rpx;
  margin: 0 10rpx 20rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  gap: 16rpx;
  box-shadow: 0 4rpx 12rpx rgba(240, 147, 251, 0.3);
}

.recording-icon {
  font-size: 36rpx;
}

.recording-text {
  font-size: 28rpx;
  font-weight: 500;
}

/* 录音按钮 */
.record-button {
  width: 100%;
  height: 96rpx;
  line-height: 96rpx;
  background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);
  color: white;
  border-radius: 48rpx;
  font-size: 32rpx;
  font-weight: 500;
  border: none;
  box-shadow: 0 8rpx 24rpx rgba(240, 147, 251, 0.4);
}

.record-button.recording {
  background: #ef4444;
  animation: pulse-glow 1.5s infinite;
}

@keyframes pulse-glow {
  0%, 100% { box-shadow: 0 0 0 0 rgba(239, 68, 68, 0.4); }
  50% { box-shadow: 0 0 30rpx 10rpx rgba(239, 68, 68, 0.2); }
}

/* 弹窗样式和首页保持一致 */
.modal-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.7);
  z-index: 999;
  display: flex;
  align-items: center;
  justify-content: center;
}

.modal-content {
  width: 80%;
  background: #1a1a2e;
  border: 1rpx solid rgba(255, 255, 255, 0.1);
  border-radius: 20rpx;
  padding: 40rpx 30rpx;
  box-sizing: border-box;
}

.modal-title {
  font-size: 32rpx;
  font-weight: 500;
  color: rgba(255, 255, 255, 0.9);
  text-align: center;
  margin-bottom: 30rpx;
}

.timer-picker {
  margin-bottom: 30rpx;
}

.picker-display {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.9);
  padding: 20rpx;
  background: rgba(255, 255, 255, 0.06);
  border-radius: 12rpx;
}

.modal-buttons {
  display: flex;
  gap: 20rpx;
  justify-content: flex-end;
}

.modal-buttons .btn {
  min-width: 140rpx;
  border-radius: 40rpx;
  font-size: 28rpx;
}

.modal-buttons .btn.cancel {
  background: rgba(255, 255, 255, 0.06);
  color: rgba(255, 255, 255, 0.5);
}

.modal-buttons .btn.confirm {
  background: linear-gradient(135deg, #7c3aed 0%, #a855f7 100%);
  color: white;
}

/* 录音中蒙版 - 情感化 */
.recording-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(180deg, #1a0a10 0%, #2d0f1a 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 999;
}

.recording-indicator {
  text-align: center;
  color: white;
  padding: 0 60rpx;
}

.big-pulse {
  width: 160rpx;
  height: 160rpx;
  background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);
  border-radius: 50%;
  margin: 0 auto 32rpx;
  animation: big-pulse-ring 1.5s infinite;
}

@keyframes big-pulse-ring {
  0% { transform: scale(0.8); opacity: 1; box-shadow: 0 0 0 0 rgba(240, 147, 251, 0.6); }
  50% { transform: scale(1); opacity: 0.9; }
  100% { transform: scale(1.2); opacity: 0; box-shadow: 0 0 60rpx 20rpx rgba(240, 147, 251, 0); }
}

.recording-timer {
  font-size: 72rpx;
  font-weight: 300;
  margin-bottom: 16rpx;
}

.recording-hint {
  font-size: 28rpx;
  opacity: 0.8;
  margin-bottom: 16rpx;
}

.recording-tip {
  font-size: 24rpx;
  opacity: 0.6;
  margin-bottom: 48rpx;
  line-height: 1.5;
}

.stop-record-btn {
  width: 280rpx;
  height: 88rpx;
  line-height: 88rpx;
  background: #ef4444;
  color: white;
  border-radius: 44rpx;
  font-size: 30rpx;
  font-weight: 500;
  border: none;
  margin: 0 auto;
  padding: 0;
  box-shadow: 0 8rpx 24rpx rgba(239, 68, 68, 0.4);
}
