.container {
  min-height: 100vh;
  padding: 20rpx;
  /* 留出底部固定栏空间（player-bar + 录音按钮 + tabBar）*/
  padding-bottom: 360rpx;
  background-color: #f5f7fa;
}

.bottom-spacer {
  height: 220rpx;
}

.bottom-fixed {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #f5f7fa;
  box-sizing: border-box;
  padding: 10rpx 20rpx;
  /* 留出 tabBar 高度，避免被挡住 */
  padding-bottom: 100rpx;
}

.recordings-list {
  margin-bottom: 20rpx;
}

.recording-item {
  background: white;
  border-radius: 12rpx;
  margin-bottom: 16rpx;
  overflow: hidden;
}

.recording-actions {
  display: flex;
  justify-content: flex-end;
  padding: 0 20rpx 16rpx;
}

.action-btn {
  font-size: 24rpx;
  padding: 8rpx 16rpx;
  border-radius: 6rpx;
  background: #f0f0f0;
  color: #666;
  line-height: 1.4;
  margin-left: 8rpx;
}

.action-btn:first-child {
  margin-left: 0;
}

.action-btn.delete {
  background: #ffebee;
  color: #f44336;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  margin-top: 200rpx;
  color: #999;
}

.empty-icon {
  font-size: 120rpx;
  margin-bottom: 24rpx;
}

.empty-text {
  font-size: 32rpx;
  margin-bottom: 12rpx;
}

.empty-hint {
  font-size: 26rpx;
}

.record-button-wrapper {
  /* 已经在 bottom-fixed 容器中，不需要再 fixed */
  padding: 20rpx 0;
}

.record-count-hint {
  text-align: center;
  font-size: 22rpx;
  color: #999;
  margin-bottom: 12rpx;
}

.record-button {
  width: 100%;
  height: 96rpx;
  line-height: 96rpx;
  background: #4A6FA5;
  color: white;
  border-radius: 48rpx;
  font-size: 32rpx;
  font-weight: 500;
  border: none;
}

.record-button.recording {
  background: #f44336;
  animation: pulse 1.5s infinite;
}

@keyframes pulse {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.7; }
}

/* 弹窗样式和首页保持一致 */
.modal-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 999;
  display: flex;
  align-items: center;
  justify-content: center;
}

.modal-content {
  width: 80%;
  background: white;
  border-radius: 12rpx;
  padding: 30rpx;
  box-sizing: border-box;
}

.modal-title {
  font-size: 32rpx;
  font-weight: 500;
  color: #333;
  text-align: center;
  margin-bottom: 30rpx;
}

.timer-picker {
  margin-bottom: 30rpx;
}

.picker-display {
  font-size: 28rpx;
  color: #333;
  padding: 20rpx;
  background: #f5f7fa;
  border-radius: 8rpx;
}

.modal-buttons {
  display: flex;
  gap: 20rpx;
  justify-content: flex-end;
}

.modal-buttons .btn {
  min-width: 140rpx;
  border-radius: 8rpx;
  font-size: 28rpx;
}

.modal-buttons .btn.cancel {
  background: #f0f0f0;
  color: #666;
}

.modal-buttons .btn.confirm {
  background: #4A6FA5;
  color: white;
}

.recording-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.7);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 999;
}

.recording-indicator {
  text-align: center;
  color: white;
}

.pulse {
  width: 120rpx;
  height: 120rpx;
  background: #f44336;
  border-radius: 50%;
  margin: 0 auto 24rpx;
  animation: pulse-ring 1.5s infinite;
}

@keyframes pulse-ring {
  0% { transform: scale(0.8); opacity: 1; }
  100% { transform: scale(1.3); opacity: 0; }
}

.recording-timer {
  font-size: 64rpx;
  font-weight: bold;
  margin-bottom: 12rpx;
}

.recording-hint {
  font-size: 26rpx;
  opacity: 0.8;
}