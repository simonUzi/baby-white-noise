.player-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #ffffff;
  padding: 20rpx 30rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  box-shadow: 0 -4rpx 12rpx rgba(0, 0, 0, 0.1);
  z-index: 100;
  display: flex;
  flex-direction: column;
}

.player-info {
  text-align: center;
  margin-bottom: 16rpx;
}

.current-name {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}

.timer {
  font-size: 24rpx;
  color: #4A6FA5;
  margin-top: 4rpx;
}

.player-controls {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 20rpx;
}

.control-btn {
  flex: 1;
  height: 80rpx;
  line-height: 80rpx;
  border-radius: 40rpx;
  font-size: 28rpx;
  border: none;
  padding: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
}

.timer-btn {
  background: #f0f0f0;
  color: #333;
}

.play-btn {
  background: #4A6FA5;
  color: #ffffff;
  transform: scale(1.1);
}

.play-btn.playing {
  background: #6b8cbc;
}

.stop-btn {
  background: #f0f0f0;
  color: #666;
}