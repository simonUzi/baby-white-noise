/* 声音卡片 - 暗黑主题 */
.sound-card {
  position: relative;
  background: rgba(255, 255, 255, 0.06);
  border: 1rpx solid rgba(255, 255, 255, 0.08);
  border-radius: 20rpx;
  padding: 32rpx 24rpx;
  margin-bottom: 24rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  transition: all 0.3s ease;
  min-height: 180rpx;
  box-sizing: border-box;
}

.sound-card.playing {
  background: rgba(168, 85, 247, 0.2);
  border-color: #a855f7;
  transform: scale(1.02);
  /* 柔和的呼吸动画 */
  animation: card-breathe 3s ease-in-out infinite;
  box-shadow: 0 0 30rpx rgba(168, 85, 247, 0.2);
}

@keyframes card-breathe {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.9; }
}

.sound-card:active {
  transform: scale(0.98);
}

.sound-icon {
  font-size: 64rpx;
  margin-bottom: 16rpx;
}

.sound-name {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.9);
  text-align: center;
  line-height: 1.4;
}

/* 收藏按钮 */
.favorite-btn {
  position: absolute;
  top: 12rpx;
  right: 12rpx;
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(255, 255, 255, 0.08);
  border-radius: 50%;
  font-size: 28rpx;
  line-height: 1;
  opacity: 0.6;
  transition: all 0.3s ease;
}

.favorite-btn.collected {
  background: rgba(251, 191, 36, 0.15);
  opacity: 1;
  transform: scale(1.1);
}
